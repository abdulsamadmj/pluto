{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "pnpm --filter=@repo/web build",
    "build:server": "pnpm --filter=@repo/server build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter=@repo/web dev",
    "dev:server": "pnpm --filter=@repo/server dev",
    "dev:mobile": "pnpm --filter=@repo/mobile dev",
    "start": "pnpm --filter=@repo/server start",
    "preview": "pnpm --filter=@repo/web preview",
    "mobile:ios": "pnpm --filter=@repo/mobile ios",
    "mobile:android": "pnpm --filter=@repo/mobile android",
    "mobile:ios:prod": "pnpm --filter=@repo/mobile ios:prod",
    "mobile:android:prod": "pnpm --filter=@repo/mobile android:prod",
    "mobile:ios:desktop": "pnpm --filter=@repo/mobile ios:desktop",
    "lint": "turbo run lint",
    "typecheck": "pnpm --filter=@repo/mobile typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "pnpm --filter=@repo/server db:push",
    "db:seed": "pnpm --filter=@repo/server db:seed",
    "db:studio": "pnpm --filter=@repo/server db:studio",
    "ui-add": "turbo run ui-add --ui=tui",
    "create:route": "pnpm --filter=@repo/server create:route"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@8.15.6",
  "name": "reno-stack-monorepo",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@>=5.0.0 <5.4.18": ">=5.4.18",
      "better-auth": "1.3.34",
      "@better-auth/expo": "1.3.34",
      "@types/react": "19.0.14",
      "@types/react-dom": "19.0.4"
    }
  }
}