DATABASE_URL="postgresql://postgres:postgres@localhost:5434/warranty"
BETTER_AUTH_SECRET="generate-a-long-random-string-here"
VITE_SERVER_URL="http://localhost:8080"
WEB_URL="http://localhost:5173"

# --- Warranty-card scan (OCR) ---
# OpenAI vision model reads the card/receipt and extracts device fields.
OPENAI_API_KEY="sk-..."
# Optional — defaults to gpt-4o-mini (vision + structured output capable).
OPENAI_MODEL="gpt-4o-mini"

# --- Cloudflare R2 (stores the scanned card image) ---
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="warranty-cards"
# Optional — public bucket / custom domain base URL for serving images.
# When unset, the API returns short-lived presigned URLs instead.
R2_PUBLIC_URL="https://cards.example.com"
