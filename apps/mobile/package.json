    "@hookform/resolvers": "^5.1.1",
    "@reno-stack/hono-react-query": "^0.0.2",
    "@repo/server": "workspace:*",
    "@repo/validators": "workspace:*",
    "@tanstack/react-query": "^5.83.0",
    "better-auth": "^1.3.2",
    "expo": "~53.0.0",
    "expo-constants": "~17.1.6",
    "expo-dev-client": "~5.2.4",
    "expo-image-picker": "~16.1.4",
